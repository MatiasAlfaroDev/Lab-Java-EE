<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="chatPU" transaction-type="JTA">
        <jta-data-source>java:/jdbc/ChatDS</jta-data-source>

        <class>com.chat.model.Usuario</class>
        <class>com.chat.model.Chat</class>
        <class>com.chat.model.MiembroChat</class>
        <class>com.chat.model.Mensaje</class>
        <class>com.chat.model.MensajeUsuario</class>
        <class>com.chat.model.ReaccionMensaje</class>
        <class>com.chat.model.Adjunto</class>
        <class>com.chat.model.ClaveGrupo</class>
        <class>com.chat.model.Encuesta</class>
        <class>com.chat.model.OpcionEncuesta</class>
        <class>com.chat.model.VotoEncuesta</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
